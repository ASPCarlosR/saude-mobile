# ── Servidor ──────────────────────────────────────────────────────────
PORT=3333

# ── Banco de dados do PAINEL (PostgreSQL) ──────────────────────────────
# Nunca suba o .env real para o git — apenas este .env.example
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nome_do_banco
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco

# ── Autenticação JWT ───────────────────────────────────────────────────
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_POR_UMA_CHAVE_FORTE_DE_48_BYTES

# ── Credenciais do painel admin ────────────────────────────────────────
ADMIN_PANEL_EMAIL=admin@seudominio.com
ADMIN_PANEL_PASSWORD=TROQUE_POR_SENHA_FORTE

# ── Chave de criptografia AES-256 para db_pass dos municípios ─────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=TROQUE_POR_64_CHARS_HEX_ALEATORIOS
